# ============================================================
#  KodingvillageSchool — Variables d'environnement
#  Copiez ce fichier en `.env` (local) et/ou déclarez ces clés
#  dans Vercel → Settings → Environment Variables (production).
#  NE COMMITEZ JAMAIS le vrai `.env` (il est ignoré par git).
# ============================================================

# ------------------------------------------------------------
#  ZOOM — Server-to-Server OAuth (recommandé par Zoom)
#  1. https://marketplace.zoom.us → Develop → Build App
#  2. Type d'app : « Server-to-Server OAuth »
#  3. Scopes requis : meeting:read:admin  (lecture des réunions)
#  4. Copiez les 3 identifiants ci-dessous depuis l'onglet « App Credentials »
# ------------------------------------------------------------
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# ------------------------------------------------------------
#  Correspondance COURS → RÉUNION ZOOM (JSON sur une ligne)
#  Clé   = courseId utilisé dans le front (attribut data-course des cartes .cc
#          côté élève, et champ `course` des teacherClasses côté enseignant)
#  Valeur = Meeting ID Zoom (numérique) de la réunion planifiée pour ce cours
#
#  courseIds supportés par l'application :
#    dev-jeux-python  → Développement de jeux (Python)
#    python-boucles   → Python · Les boucles
#    python-poo       → Python · POO (programmation orientée objet)
#    python-fonctions → Python · Les fonctions
#    scratch          → Scratch
#    vibe-coding      → Laboratoire de Codage Vibe
#  (Ajoutez une entrée ici pour activer un nouveau cours ; un courseId absent
#   de cette map renvoie 404 → le front bascule sur la salle de classe démo.)
# ------------------------------------------------------------
ZOOM_COURSE_MEETINGS={"dev-jeux-python":"REMPLACER_PAR_MEETING_ID","python-boucles":"REMPLACER_PAR_MEETING_ID","python-poo":"REMPLACER_PAR_MEETING_ID","python-fonctions":"REMPLACER_PAR_MEETING_ID","scratch":"REMPLACER_PAR_MEETING_ID","vibe-coding":"REMPLACER_PAR_MEETING_ID"}

# ------------------------------------------------------------
#  OPTION B (facultatif) — Web Meeting SDK (@zoomus/websdk)
#  Nécessaire UNIQUEMENT pour incruster la vidéo directement dans
#  l'espace « Mentor Sarah — En direct ». Laissez vide tant que vous
#  utilisez l'OPTION A (redirection vers l'app Zoom).
#  App de type « Meeting SDK » sur le Marketplace → Client ID/Secret dédiés.
# ------------------------------------------------------------
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# ------------------------------------------------------------
#  CONTACT — affiché dans le pied de page de TOUS les e-mails
#  (api/_brand.js). Laisser vide = valeurs par défaut ci-dessous.
# ------------------------------------------------------------
CONTACT_EMAIL=info@kodingvillageschool.com
WHATSAPP_NUMBER=16044992735
PHONE_DISPLAY=+1 604 499 2735
PUBLIC_URL=https://kodingvillageschool.com

# ------------------------------------------------------------
#  RAPPELS AUTOMATIQUES avant les cours (api/reminders.js)
#
#  CRON_SECRET protège l'endpoint : sans lui, n'importe qui pourrait
#  déclencher des envois en masse. Générer une valeur aléatoire :
#      openssl rand -hex 32
#
#  ⚙️ DÉCLENCHEUR ACTIF : GitHub Actions (plan Vercel Hobby).
#  Le workflow .github/workflows/reminders.yml appelle l'endpoint toutes
#  les 10 min. Il faut déclarer LES MÊMES valeurs des deux côtés :
#    • Vercel  → Settings → Environment Variables : CRON_SECRET
#    • GitHub  → Settings → Secrets → Actions     : CRON_SECRET + SITE_URL
#  (Alternative sans GitHub : cron-job.org, même appel HTTP.
#   Si tu passes un jour en Vercel Pro, ajoute plutôt dans vercel.json :
#     "crons": [{ "path": "/api/reminders", "schedule": "*/10 * * * *" }]
#   et désactive le workflow GitHub pour éviter les doublons.)
# ------------------------------------------------------------
CRON_SECRET=
REMINDER_LEAD_MIN=60
REMINDER_TIMEZONE=America/Vancouver

# ------------------------------------------------------------
#  WHATSAPP Business — API Meta Cloud (facultatif)
#  Tant que ces clés sont vides, les rappels WhatsApp sont IGNORÉS
#  proprement (les e-mails partent quand même). Voir api/_whatsapp.js
#  pour la procédure de mise en service et le modèle à faire approuver.
# ------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=rappel_cours_1h
WHATSAPP_TEMPLATE_LANG=fr

# ------------------------------------------------------------
#  SUPPORTS DE COURS — Vercel Blob (api/_content.js)
#  Les PDF (~134 Mo) vivent hors du dépôt git.
#  Vercel → Storage → Blob → créer un store → copier le jeton.
#
#  Chemins attendus pour le module pilote « Python Niveau 1 » :
#    cours/vibe-coding/chapitre-1.pdf  … jusqu'à chapitre-8.pdf
#  Tant qu'un fichier manque, son chapitre s'affiche « Bientôt »
#  au lieu de casser la page.
# ------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=

# ============================================================
#  (Rappel) Autres services déjà utilisés par le projet
# ============================================================
# STRIPE_SECRET_KEY=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
