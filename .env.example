# ============================================================
#  KodingvillageSchool — Variables d'environnement
#  Copiez ce fichier en `.env` (local) et/ou déclarez ces clés
#  dans Vercel → Settings → Environment Variables (production).
#  NE COMMITEZ JAMAIS le vrai `.env` (il est ignoré par git).
# ============================================================

# ------------------------------------------------------------
#  ZOOM — Server-to-Server OAuth (recommandé par Zoom)
#  1. https://marketplace.zoom.us → Develop → Build App
#  2. Type d'app : « Server-to-Server OAuth »
#  3. Scopes requis : meeting:read:admin  (lecture des réunions)
#  4. Copiez les 3 identifiants ci-dessous depuis l'onglet « App Credentials »
# ------------------------------------------------------------
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# ------------------------------------------------------------
#  Correspondance COURS → RÉUNION ZOOM (JSON sur une ligne)
#  Clé   = courseId utilisé dans le front (attribut data-course des cartes .cc
#          côté élève, et champ `course` des teacherClasses côté enseignant)
#  Valeur = Meeting ID Zoom (numérique) de la réunion planifiée pour ce cours
#
#  courseIds supportés par l'application :
#    dev-jeux-python  → Développement de jeux (Python)
#    web-dev          → Web Development
#    java             → Java
#    python-boucles   → Python · Les boucles
#    python-poo       → Python · POO (programmation orientée objet)
#  (Ajoutez une entrée ici pour activer un nouveau cours ; un courseId absent
#   de cette map renvoie 404 → le front bascule sur la salle de classe démo.)
# ------------------------------------------------------------
ZOOM_COURSE_MEETINGS={"dev-jeux-python":"REMPLACER_PAR_MEETING_ID","web-dev":"REMPLACER_PAR_MEETING_ID","java":"REMPLACER_PAR_MEETING_ID","python-boucles":"REMPLACER_PAR_MEETING_ID","python-poo":"REMPLACER_PAR_MEETING_ID"}

# ------------------------------------------------------------
#  OPTION B (facultatif) — Web Meeting SDK (@zoomus/websdk)
#  Nécessaire UNIQUEMENT pour incruster la vidéo directement dans
#  l'espace « Mentor Sarah — En direct ». Laissez vide tant que vous
#  utilisez l'OPTION A (redirection vers l'app Zoom).
#  App de type « Meeting SDK » sur le Marketplace → Client ID/Secret dédiés.
# ------------------------------------------------------------
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# ============================================================
#  (Rappel) Autres services déjà utilisés par le projet
# ============================================================
# STRIPE_SECRET_KEY=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
